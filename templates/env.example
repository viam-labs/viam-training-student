# Machine credentials for the operator web app dev server.
# Copy this file to .env and fill in the values for your cell, then run
# `go run ./cmd/cli` and open http://localhost:8080.
#
# Find these under your machine's CONNECT tab (or in an API key you create
# under the machine's location). Variables already exported in your shell
# take precedence over the values here.

# Main part FQDN, e.g. my-machine-main.abc123.viam.cloud
VIAM_ROBOT_FQDN=

# API key ID (a UUID)
VIAM_API_KEY_ID=

# API key secret
VIAM_API_KEY=
